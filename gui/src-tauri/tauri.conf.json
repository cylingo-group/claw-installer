{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claw Installer",
  "version": "1.0.0",
  "identifier": "com.claw-installer.gui",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:6520",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claw Installer",
        "width": 320,
        "height": 720,
        "minWidth": 320,
        "minHeight": 720,
        "maxWidth": 320,
        "maxHeight": 720,
        "resizable": false,
        "maximizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../shell": "shell"
    }
  }
}
